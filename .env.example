# Database Configuration
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DATABASE=facedatabase

# MongoDB Collection Names
COLLECTION_BACKUP=bkpcollection
COLLECTION_CLASSES=classcollection
COLLECTION_CLUSTERS=clustercollection

# Directory Paths
SOURCE_DIR=/Volumes/data_sets/fresh_backup/images
NOFACE_DIR=/Volumes/data_sets/fresh_backup/noface
BROKEN_DIR=/Volumes/data_sets/fresh_backup/broken
CACHE_DIR=/Volumes/data_sets/fresh_backup/.cache

# Processing Settings
CACHE_QUALITY=50
SIMILARITY_THRESHOLD=0.5
CLUSTER_MIN_SAMPLES=2
BATCH_SIZE=32

# InsightFace Model Providers (comma-separated)
INSIGHTFACE_PROVIDERS=CoreMLExecutionProvider,CPUExecutionProvider

# Logging
LOG_LEVEL=INFO

# UI Configuration
UI_HOST=127.0.0.1
UI_PORT=8000
UI_RELOAD=true
UI_LOG_LEVEL=info
